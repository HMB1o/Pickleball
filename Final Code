<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pickleball Bracket Hub</title>
    <style>
        :root {
            --bg-dark: #030712;
            --bg-card: #0b1528;
            --accent-blue: #3b82f6;
            --neon-blue: #00d2ff;
            --text-light: #f3f4f6;
            --text-gray: #6b7280;
            --border-blue: #1e3a8a;
            --bronze: #cd7f32;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid var(--border-blue);
            padding-bottom: 20px;
        }

        h1 {
            color: var(--neon-blue);
            margin: 0 0 10px 0;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h2, h3 {
            color: var(--accent-blue);
            margin-top: 0;
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-blue);
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.1);
        }

        .setup-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .player-checkbox {
            background: #111827;
            border: 1px solid var(--border-blue);
            padding: 12px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            user-select: none;
        }

        .player-checkbox input {
            transform: scale(1.2);
            accent-color: var(--neon-blue);
        }

        .flex-row {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }

        input[type="text"], input[type="number"], select {
            flex: 1;
            padding: 12px;
            background: #030712;
            border: 1px solid var(--border-blue);
            color: white;
            border-radius: 6px;
            font-size: 1rem;
        }

        button {
            padding: 12px 24px;
            background: linear-gradient(135deg, var(--accent-blue), #1d4ed8);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        button:hover {
            background: linear-gradient(135deg, var(--neon-blue), var(--accent-blue));
            box-shadow: 0 0 10px rgba(0, 210, 255, 0.4);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 25px;
        }

        @media (min-width: 800px) {
            .dashboard-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid var(--border-blue);
        }

        th { color: var(--text-gray); font-size: 0.9rem; text-transform: uppercase; }

        /* Full Visual Bracket Layout */
        .bracket-wrapper {
            display: flex;
            gap: 50px;
            align-items: flex-start;
            justify-content: center;
            padding: 20px 0;
            overflow-x: auto;
        }

        .bracket-column {
            display: flex;
            flex-direction: column;
            gap: 30px;
            min-width: 260px;
        }

        .bracket-match {
            background: #030712;
            border: 1px solid var(--border-blue);
            border-radius: 8px;
            padding: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }

        .bracket-match-title {
            font-size: 0.75rem;
            color: var(--text-gray);
            text-transform: uppercase;
            margin-bottom: 8px;
            border-bottom: 1px solid #111827;
            padding-bottom: 4px;
        }

        .bracket-team {
            display: flex;
            justify-content: space-between;
            padding: 6px 4px;
            font-size: 0.95rem;
        }

        .bracket-team.winner {
            color: var(--neon-blue);
            font-weight: bold;
        }

        .bracket-team.bronze-winner {
            color: var(--bronze);
            font-weight: bold;
        }

        .bracket-score-input {
            display: flex;
            gap: 5px;
            margin-top: 8px;
        }

        .bracket-score-input input {
            width: 50px;
            padding: 4px;
            text-align: center;
        }

        .bracket-score-input button {
            padding: 4px 10px;
            font-size: 0.8rem;
        }

        .podium-container {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: center;
        }

        .banner {
            text-align: center;
            padding: 15px;
            border-radius: 8px;
            font-weight: bold;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 0 15px rgba(255,255,255,0.1);
        }

        .gold-banner {
            background: linear-gradient(90deg, #1e3a8a, #3b82f6, #1e3a8a);
            border: 1px solid var(--neon-blue);
            font-size: 1.4rem;
        }

        .bronze-banner {
            background: #1c1917;
            border: 1px solid var(--bronze);
            color: var(--bronze);
            font-size: 1.1rem;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>

